<?xml version="1.0" encoding="UTF-8"?>
<!--
	"Hay sử dụng" / Frequently-used dashboard panel.
	Boots the DPQuickLinks Java gadget which renders a responsive grid of
	cards linking to the most common admin windows. Registered via
	PA_DashboardContent.ZulFilePath = '/zul/quicklinks.zul' (see
	migration 202605071300_ISW_DashboardQuickLinks.sql).
-->
<window use="org.adempiere.webui.dashboard.DPQuickLinks"/>
